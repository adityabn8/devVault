{
  "manifest_version": 3,
  "name": "DevVault",
  "version": "1.0.0",
  "description": "Save web resources directly to your DevVault without leaving the browser.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to DevVault"
  },
  "permissions": ["activeTab", "storage", "tabs", "management"],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
